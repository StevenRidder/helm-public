  "source_policy": {
    "s52_metadata": "~/.helm/runtime/s57data/chartsymbols.xml",
    "chart_no_1_reference_root": "references/us-chart-1/",
    "clean_ip_rule": "Generate fresh owned SVG from Chart No.1 references and style primitives. Use chartsymbols.xml for metadata, lookup conditions, pivots, palette expectations, and sibling discrimination only; do not copy OpenCPN raster artwork into the owned pack."
  },
  "qa_gates": [
    "xml_wellformed",
    "palette_tokens_defined",
    "invariant_colours_used",
    "no_literal_hex",
    "anchor_in_bounds",
    "renders",
    "sibling_discrimination",
    "hard_pile_on_failure",
    "atlas_manifest_shape_name_kind_palette_plus_style"
