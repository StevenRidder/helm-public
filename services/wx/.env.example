# helm-wx gateway — environment config.
# Copy this file to  services/wx/.env  (which is git-ignored — never committed) and fill in.
# app.py loads .env on startup; real environment variables override it.
#
# Run the gateway:   cd services/wx && uvicorn app:app --port 8093
# (see services/wx/README.md). The web client expects weather on :8093.

# Open-Meteo COMMERCIAL API key — https://open-meteo.com (the "Commercial" plan; 1M calls/mo).
# WITHOUT a key the gateway falls back to the FREE, daily-capped host and will rate-limit under
# normal panning (429 -> 503 -> weather layers stop loading). WITH a key it automatically switches
# to the customer-api.open-meteo.com host, appends &apikey, and raises fetch concurrency.
# The gateway caches aggressively (disk-mirrored tiles + region grids), so a key's 1M calls go far.
HELM_WX_OPENMETEO_KEY=

# --- optional knobs (defaults shown) ---
# HELM_WX_CACHE=./cache       # tile + grid cache dir (disk-mirrored; survives restart/offline)
# HELM_WX_TTL=1800            # a fetched grid / baked tile is reusable for this many seconds (30 min)
# HELM_WX_COOLDOWN=300        # after an upstream 429, serve cache-only for this many seconds
# HELM_WX_REGION_TTL=10800    # warmed-region (native-res, "Windy parity") grid lifetime (3 h)
# HELM_WX_DATA_Z=7            # manifest maxzoom (source-data resolution ceiling)
